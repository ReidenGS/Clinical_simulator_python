# === Server-Side Only (used by server.ts proxy) ===
# These keys are NEVER sent to the browser. The server proxy
# reads them from process.env and forwards API calls securely.

# OpenAI
OPENAI_API_KEY=""
OPENAI_BASE_URL=""

# DashScope / Qwen TTS
DASHSCOPE_API_KEY=""
DASHSCOPE_BASE_URL="https://dashscope-intl.aliyuncs.com/api/v1"

# Gemini server-side TTS proxy
GEMINI_API_KEY=""

# === WARNING ===
# Do NOT use VITE_-prefixed API key vars (VITE_OPENAI_API_KEY etc.)
# They get baked into the frontend JS bundle and are visible to anyone.

# === App ===
APP_URL=""
