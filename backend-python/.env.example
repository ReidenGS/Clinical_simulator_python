# Copy this file to .env and fill in the keys you need.

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# LangChain / orchestration resilience
LANGCHAIN_MAX_RETRIES=2
LANGCHAIN_RETRY_BACKOFF_SECONDS=0.5
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=clinical-simulator

# Text providers
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Speech providers
QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/api/v1
OPENAI_TTS_MODEL=tts-1
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
QWEN_TTS_MODEL=qwen3-tts-instruct-flash
